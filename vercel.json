{
  "version": 2,
  "builds": [
    { "src": "api/proses_ai.py", "use": "@vercel/python" },
    { "src": "api/webhook.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/proses_ai", "dest": "/api/proses_ai.py" },
    { "src": "/api/webhook", "dest": "/api/webhook.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
